{
	"name": "npm-run",
	"displayName": "NPM Run",
	"description": "Run package.json scripts with single click",
	"version": "0.0.3",
	"publisher": "nikhil-patil",
	"license": "MIT",
	"author": {
		"name": "Nikhil Patil",
		"url": "https://github.com/nik-base"
	},
	"repository": {
		"url": "https://github.com/nik-base/npm-run",
		"type": "git"
	},
	"homepage": "https://github.com/nik-base/npm-run#readme",
	"bugs": {
		"url": "https://github.com/nik-base/npm-run/issues",
		"email": "nikhil.patil.3632@gmail.com"
	},
	"readmeFilename": "README.md",
	"pricing": "Free",
	"icon": "resources/icons/play-solid.png",
	"galleryBanner": {
		"color": "#000000",
		"theme": "dark"
	},
	"engines": {
		"vscode": "^1.95.0"
	},
	"categories": [
		"Other"
	],
	"keywords": [
		"npm",
		"run",
		"run task",
		"npm run",
		"pnpm run",
		"yarn run",
		"npm start",
		"script",
		"task",
		"run script",
		"npm-run"
	],
	"activationEvents": [
		"onLanguage:json",
		"workspaceContains:package.json"
	],
	"main": "./dist/extension.js",
	"contributes": {
		"configuration": {
			"title": "NPM Run",
			"properties": {
				"npm-run.enable": {
					"type": "boolean",
					"description": "Enable Run script as task from package.json",
					"default": true
				}
			}
		}
	},
	"scripts": {
		"preinstall": "npx only-allow pnpm",
		"vscode:prepublish": "pnpm run package",
		"compile": "pnpm run check-types && pnpm run lint && node esbuild.js",
		"watch": "pnpm run /^watch:.*/",
		"watch:esbuild": "node esbuild.js --watch",
		"watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
		"package": "pnpm run check-types && pnpm run lint && node esbuild.js --production",
		"compile:tests": "tsc -p tsconfig.test.json --outDir out",
		"watch:tests": "tsc -p tsconfig.test.json -w --outDir out",
		"pretest": "pnpm run compile:tests && pnpm run compile",
		"check-types": "tsc --noEmit -p tsconfig.json",
		"lint": "eslint src",
		"lint:fix": "eslint src --fix",
		"test:e2e": "wdio run ./test/e2e/wdio.conf.ts",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:ui": "vitest --ui",
		"test:coverage": "vitest run --coverage",
		"test:all": "pnpm run test && pnpm run test:e2e"
	},
	"devDependencies": {
		"@eslint/eslintrc": "3.3.5",
		"@eslint/js": "10.0.1",
		"@serenity-js/assertions": "3.41.2",
		"@serenity-js/console-reporter": "3.41.2",
		"@serenity-js/core": "3.41.2",
		"@serenity-js/mocha": "3.41.2",
		"@serenity-js/serenity-bdd": "3.41.2",
		"@serenity-js/web": "3.41.2",
		"@serenity-js/webdriverio": "3.41.2",
		"@types/mocha": "10.0.10",
		"@types/node": "25.5.0",
		"@types/vscode": "1.95.0",
		"@vitest/coverage-v8": "^4.1.0",
		"@vitest/ui": "^4.1.0",
		"@wdio/cli": "9.25.0",
		"@wdio/dot-reporter": "9.25.0",
		"@wdio/globals": "^9.23.0",
		"@wdio/local-runner": "9.25.0",
		"@wdio/spec-reporter": "9.25.0",
		"esbuild": "0.27.4",
		"eslint": "10.0.3",
		"eslint-config-prettier": "10.1.8",
		"prettier": "3.8.1",
		"ts-node": "10.9.2",
		"typescript": "5.9.3",
		"typescript-eslint": "^8.57.0",
		"vitest": "^4.1.0",
		"wdio-vscode-service": "6.1.4",
		"wdio-wait-for": "3.1.1"
	}
}
